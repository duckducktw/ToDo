AUTH_URL=http://localhost:3000
AUTH_SECRET=replace-with-at-least-32-random-characters
AUTH_GOOGLE_ID=replace-with-google-oauth-client-id
AUTH_GOOGLE_SECRET=replace-with-google-oauth-client-secret
DATA_STORE_DIR=src/data
APP_DEFAULT_TIMEZONE=Asia/Taipei

# Automated browser tests only. Never enable this for a public instance.
AUTH_TEST_MODE=false
TEST_AUTH_SECRET=
CALENDAR_FIXTURE_PATH=
